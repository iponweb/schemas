package main

import (
	"encoding/json"
	"fmt"
	"io"
	"log"
	"net/http"
	"sort"
	"strings"

	generated "openapi-json-gen/openapi"

	"k8s.io/apimachinery/pkg/runtime"
	"k8s.io/apiserver/pkg/endpoints/openapi"
	"k8s.io/kube-openapi/pkg/builder"
	"k8s.io/kube-openapi/pkg/common"
	"k8s.io/kube-openapi/pkg/validation/spec"
)

const (
	kubernetesSwaggerUrl = "${kubernetes_swagger_url}"
)

var (
	// crdNames correspond to the internal OpenAPI definition names of the
	// CRDs we're interested in. Dependencies do not need to be listed, as
	// they will be calculated on build.
	crdNames = []string{
${crd_names}
	}

	hostConversionRules = map[string]string{
${host_conversion_rules}
	}

	// typeAliases maps Go type paths that cannot be processed by openapi-gen
	// (e.g. types in packages with generic/incompatible fields) to equivalent
	// types that ARE in the generated definitions. The schema for the alias
	// target is reused verbatim for the original name.
	typeAliases = map[string]string{
${type_aliases}
	}
)

func reverse[T comparable](input []T) []T {
	var output []T
	for i := len(input) - 1; i >= 0; i-- {
		output = append(output, input[i])
	}
	return output
}

func loadVanilla() spec.Swagger {
	response, err := http.Get(kubernetesSwaggerUrl)
	if err != nil {
		log.Fatalf("cannot open swagger.json: %+v", err)
	}
	defer response.Body.Close()

	rawSchema, err := io.ReadAll(response.Body)
	if err != nil {
		log.Fatalf("cannot read swagger.json: %+v", err)
	}

	var schema spec.Swagger
	if err := json.Unmarshal(rawSchema, &schema); err != nil {
		log.Fatalf("cannot unmarshal swagger.json: %+v", err)
	}
	return schema
}

func main() {
	// load the swagger.json from kubernetes, which we're using here as a hack
	// to provide any references not already included by openapi-gen in the
	// controller API group.
	vanilla := loadVanilla()

	// use the same naming scheme that kubernetes uses, i.e., reverse domain
	// group, followed by version, then kind
	namer := openapi.NewDefinitionNamer(runtime.NewScheme())

	// construct a getter that uses the controller's definitions as the primary,
	// falling back onto vanilla Kubernetes definitions
	definitionGetter := mergedDefinitions(generated.GetOpenAPIDefinitions, vanilla.Definitions, namer)

	// Build a set for O(1) CRD root-type lookup inside GetDefinitionName.
	crdNameSet := make(map[string]bool, len(crdNames))
	for _, n := range crdNames {
		crdNameSet[n] = true
	}

	// Pre-sort host conversion rule keys longest-first once, rather than on
	// every GetDefinitionName call.
	ruleKeys := make([]string, 0, len(hostConversionRules))
	for k := range hostConversionRules {
		ruleKeys = append(ruleKeys, k)
	}
	sort.Slice(ruleKeys, func(i, j int) bool {
		return len(ruleKeys[i]) > len(ruleKeys[j])
	})

	cfg := &common.Config{
		Info: &spec.Info{
			InfoProps: spec.InfoProps{
				Title:   "${title}",
				Version: "v1",
			},
		},
		GetDefinitions: definitionGetter,
		GetDefinitionName: func(name string) (string, spec.Extensions) {
			originalName := name // save before mutation for GVK lookup

			ruleMatched := false
			for _, f := range ruleKeys {
				t := hostConversionRules[f]
				if strings.HasPrefix(name, f+"/") {
					// Sub-package match: "module/pkg/version/..." → keep path as-is
					name = t + name[len(f):]
					ruleMatched = true
					break
				}
				if strings.HasPrefix(name, f+".") {
					// Exact package match: "module/pkg/version.Type"
					// Extract the version (last path segment of f) so that the
					// version is preserved in the rewritten name:
					// "host/version.Type" → "rev.host.version.Type"
					fSlash := strings.LastIndex(f, "/")
					version := f[fSlash+1:]
					typeName := name[len(f)+1:] // skip the "."
					name = t + "/" + version + "." + typeName
					ruleMatched = true
					break
				}
			}

			sep := strings.Index(name, "/")
			if sep < 0 {
				return name, nil
			}

			hostname := name[:sep]
			path := name[sep+1:]

			// For controller types (host conversion applied) strip the
			// intermediate Go package path and keep only {version}.{Kind},
			// matching the naming kube-apiserver uses for CRD types in
			// /openapi/v2: com.coreos.monitoring.v1.Alertmanager.
			// For k8s built-in types keep the full path for compatibility
			// with vanilla swagger.json definition names.
			if ruleMatched {
				if slash := strings.LastIndex(path, "/"); slash >= 0 {
					path = path[slash+1:]
				}
			}

			definitionName := fmt.Sprintf("%s.%s",
				strings.Join(reverse(strings.Split(hostname, ".")), "."),
				strings.Replace(path, "/", ".", -1),
			)

			// Inject x-kubernetes-group-version-kind for root CRD types so that
			// source-generated schemas carry the same GVK annotation as live ones.
			// After host conversion + path stripping:
			//   hostname = API group  (e.g. "karpenter.k8s.aws")
			//   path     = "version.Kind"  (e.g. "v1.EC2NodeClass")
			var extensions spec.Extensions
			if ruleMatched && crdNameSet[originalName] {
				if dotIdx := strings.LastIndex(path, "."); dotIdx >= 0 {
					extensions = spec.Extensions{
						"x-kubernetes-group-version-kind": []map[string]string{
							{
								"group":   hostname,
								"kind":    path[dotIdx+1:],
								"version": path[:dotIdx],
							},
						},
					}
				}
			}

			return definitionName, extensions
		},
	}

	// generate swagger for our CRD names
	swag, err := builder.BuildOpenAPIDefinitionsForResources(cfg, crdNames...)
	if err != nil {
		log.Fatalf("cannot build openapi definitions: %+v", err)
	}

	// emit the new schema as json
	j, err := json.MarshalIndent(swag, "", "  ")
	if err != nil {
		log.Fatalf("cannot marshal: %+v", err)
	}
	fmt.Println(string(j))
}

func mergedDefinitions(primary common.GetOpenAPIDefinitions, fallback spec.Definitions, namer *openapi.DefinitionNamer) common.GetOpenAPIDefinitions {
	all := map[string]common.OpenAPIDefinition{}
	return func(ref common.ReferenceCallback) map[string]common.OpenAPIDefinition {
		// This allows us to insert extra logic during callback processing,
		// by inserting the schema from the fallback into "all". Technically
		// not fully correct, because if the schema in question doesn't exist
		// in fallback, we continue anyway and hope that the primary definition
		// will have provided the schema (it would error out if not the case).
		ref2 := func(name string) spec.Ref {
			if _, ok := all[name]; !ok {
				stdName, _ := namer.GetDefinitionName(name)
				if v, ok2 := fallback[stdName]; ok2 {
					all[name] = common.OpenAPIDefinition{
						Schema: v,
					}
				}
			}
			return ref(name)
		}
		// Copy whatever primary schemas as-is. References are resolved
		// during this primary(ref2) call.
		//
		// Doing the operations in this order does mean that only referenced
		// schemas from the fallback will be included in the final output.
		for k, v := range primary(ref2) {
			all[k] = v
		}
		// Apply type aliases: for types that couldn't be processed directly
		// by openapi-gen, copy the schema from an equivalent known type.
		// First check the generated definitions, then fall back to the
		// vanilla Kubernetes swagger.
		for name, alias := range typeAliases {
			if _, ok := all[name]; !ok {
				if aliasDef, ok2 := all[alias]; ok2 {
					all[name] = aliasDef
				} else {
					stdName, _ := namer.GetDefinitionName(alias)
					if v, ok3 := fallback[stdName]; ok3 {
						all[name] = common.OpenAPIDefinition{Schema: v}
					}
				}
			}
		}
		return all
	}
}
