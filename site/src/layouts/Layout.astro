---
export interface Props {
  title: string
  description?: string
  breadcrumbs?: { label: string; href: string }[]
}

const { title, description = 'Kubernetes CRD Schema Explorer', breadcrumbs = [] } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<!doctype html>
<html lang="en" class="bg-zinc-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — Kube Schemas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      @import "tailwindcss";

      :root {
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-mono: 'JetBrains Mono', monospace;
      }

      body {
        font-family: var(--font-sans);
      }

      code, .font-mono {
        font-family: var(--font-mono);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col text-zinc-800">
    <!-- Top Navigation -->
    <header class="bg-white border-b border-zinc-200 sticky top-0 z-50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <!-- Logo -->
          <a href={`${base}/`} class="flex items-center gap-2 group">
            <div class="w-7 h-7 rounded-lg bg-violet-600 flex items-center justify-center">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <span class="font-semibold text-zinc-900 group-hover:text-violet-600 transition-colors">
              kube schemas
            </span>
          </a>

          <!-- Breadcrumbs -->
          {breadcrumbs.length > 0 && (
            <nav class="hidden md:flex items-center gap-1 text-sm text-zinc-500 overflow-x-auto">
              <a href={`${base}/`} class="hover:text-violet-600 transition-colors whitespace-nowrap">Home</a>
              {breadcrumbs.map((crumb, i) => (
                <>
                  <svg class="w-4 h-4 text-zinc-300 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                  {i === breadcrumbs.length - 1 ? (
                    <span class="text-zinc-800 font-medium whitespace-nowrap">{crumb.label}</span>
                  ) : (
                    <a href={crumb.href} class="hover:text-violet-600 transition-colors whitespace-nowrap">{crumb.label}</a>
                  )}
                </>
              ))}
            </nav>
          )}

          <!-- Right side actions -->
          <div class="flex items-center gap-3">
            <a
              href="https://github.com/iponweb/schemas"
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-500 hover:text-zinc-800 transition-colors"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-zinc-200 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <div class="w-5 h-5 rounded bg-violet-600 flex items-center justify-center">
              <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <span class="text-sm text-zinc-500">Generated from open-source CRD schemas</span>
          </div>
          <a
            href="https://github.com/iponweb/schemas"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-zinc-400 hover:text-violet-600 transition-colors"
          >
            iponweb/schemas
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
