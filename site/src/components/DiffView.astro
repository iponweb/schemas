---
import type { VersionDiff } from '../lib/types'

export interface Props {
  diff: VersionDiff
  versionNew: string
  versionOld: string
}

const { diff, versionNew, versionOld } = Astro.props

const hasChanges = diff.added.length > 0 || diff.removed.length > 0 || diff.changed.length > 0
---

{!hasChanges ? (
  <div class="bg-zinc-50 border border-zinc-200 rounded-xl p-6 text-center text-zinc-400 text-sm">
    No changes between <span class="font-mono">{versionOld}</span> and <span class="font-mono">{versionNew}</span>
  </div>
) : (
  <div class="space-y-4">
    <!-- Summary badges -->
    <div class="flex flex-wrap gap-2">
      {diff.added.length > 0 && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-emerald-100 text-emerald-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          {diff.added.length} added
        </span>
      )}
      {diff.removed.length > 0 && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-rose-100 text-rose-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
          </svg>
          {diff.removed.length} removed
        </span>
      )}
      {diff.changed.length > 0 && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-sm font-medium bg-amber-100 text-amber-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          {diff.changed.length} changed
        </span>
      )}
    </div>

    <!-- Added resources -->
    {diff.added.length > 0 && (
      <div class="bg-emerald-50 border border-emerald-200 rounded-xl overflow-hidden">
        <div class="px-4 py-3 bg-emerald-100 border-b border-emerald-200">
          <h3 class="text-sm font-semibold text-emerald-800">Added resources</h3>
        </div>
        <div class="divide-y divide-emerald-100">
          {diff.added.map(resource => (
            <div class="px-4 py-3 flex items-center justify-between gap-4">
              <div class="flex items-center gap-3">
                <span class="text-emerald-500">+</span>
                <span class="font-mono font-semibold text-emerald-800">{resource.kind}</span>
                <span class="font-mono text-xs text-emerald-600 hidden sm:inline">
                  {resource.group || 'core'}/{resource.version}
                </span>
              </div>
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
                resource.scope === 'Namespaced'
                  ? 'bg-blue-100 text-blue-700'
                  : 'bg-amber-100 text-amber-700'
              }`}>
                {resource.scope}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Removed resources -->
    {diff.removed.length > 0 && (
      <div class="bg-rose-50 border border-rose-200 rounded-xl overflow-hidden">
        <div class="px-4 py-3 bg-rose-100 border-b border-rose-200">
          <h3 class="text-sm font-semibold text-rose-800">Removed resources</h3>
        </div>
        <div class="divide-y divide-rose-100">
          {diff.removed.map(resource => (
            <div class="px-4 py-3 flex items-center justify-between gap-4">
              <div class="flex items-center gap-3">
                <span class="text-rose-500">-</span>
                <span class="font-mono font-semibold text-rose-800">{resource.kind}</span>
                <span class="font-mono text-xs text-rose-600 hidden sm:inline">
                  {resource.group || 'core'}/{resource.version}
                </span>
              </div>
              <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
                resource.scope === 'Namespaced'
                  ? 'bg-blue-100 text-blue-700'
                  : 'bg-amber-100 text-amber-700'
              }`}>
                {resource.scope}
              </span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Changed resources -->
    {diff.changed.length > 0 && (
      <div class="bg-amber-50 border border-amber-200 rounded-xl overflow-hidden">
        <div class="px-4 py-3 bg-amber-100 border-b border-amber-200">
          <h3 class="text-sm font-semibold text-amber-800">Changed resources (spec fields)</h3>
        </div>
        <div class="divide-y divide-amber-100">
          {diff.changed.map(({ resource, addedFields, removedFields }) => (
            <div class="px-4 py-3">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-amber-500">~</span>
                <span class="font-mono font-semibold text-amber-800">{resource.kind}</span>
                <span class="font-mono text-xs text-amber-600 hidden sm:inline">
                  {resource.group || 'core'}/{resource.version}
                </span>
              </div>
              <div class="flex flex-wrap gap-1.5 pl-5">
                {addedFields.map(field => (
                  <span class="inline-flex items-center gap-1 text-xs font-mono bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded border border-emerald-200">
                    +{field}
                  </span>
                ))}
                {removedFields.map(field => (
                  <span class="inline-flex items-center gap-1 text-xs font-mono bg-rose-100 text-rose-700 px-2 py-0.5 rounded border border-rose-200">
                    -{field}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
)}
