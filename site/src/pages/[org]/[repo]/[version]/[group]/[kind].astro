---
import Layout from '../../../../../layouts/Layout.astro'
import PropertyTree from '../../../../../components/PropertyTree'
import ChangeHistory from '../../../../../components/ChangeHistory'
import { getAllControllers, getResources, getResourceSchema, getResourceSchemaFromDefinitions, getDefinitions, getChangeHistory, getResourceAssets, getControllerMeta } from '../../../../../lib/data'
import type { ChangeHistoryEntry } from '../../../../../lib/data'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const controllers = getAllControllers()
  const paths: {
    params: { org: string; repo: string; version: string; group: string; kind: string }
    props: object
  }[] = []

  const historyCache = new Map<string, ChangeHistoryEntry[]>()

  for (const ctrl of controllers) {
    for (const version of ctrl.versions) {
      const resources = getResources(ctrl.org, ctrl.repo, version)
      for (const resource of resources) {
        const cacheKey = `${ctrl.org}/${ctrl.repo}/${resource.group}/${resource.kind}`
        let changeHistory: ChangeHistoryEntry[]
        if (historyCache.has(cacheKey)) {
          changeHistory = historyCache.get(cacheKey)!
        } else {
          changeHistory = getChangeHistory(
            ctrl.org,
            ctrl.repo,
            ctrl.versions,
            resource.plural,
            resource.group,
            resource.version,
            resource.kind,
          )
          historyCache.set(cacheKey, changeHistory)
        }
        paths.push({
          params: {
            org: ctrl.org,
            repo: ctrl.repo,
            version,
            group: resource.group || 'core',
            kind: resource.kind,
          },
          props: { resource, ctrl, changeHistory },
        })
      }
    }
  }
  return paths
}

const { resource, ctrl, changeHistory } = Astro.props as {
  resource: import('../../../../../lib/types').Resource
  ctrl: import('../../../../../lib/types').Controller
  changeHistory: ChangeHistoryEntry[]
}
const { org, repo, version, group } = Astro.params
const label = repo.charAt(0).toUpperCase() + repo.slice(1)
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// Try to get schema from CRD, then fall back to definitions (for kubernetes/)
let schema = null
let definitions: Record<string, import('../../../../../lib/types').SchemaProperty> = {}
const isKubernetes = org === 'kubernetes' && repo === 'kubernetes'

if (!isKubernetes) {
  schema = getResourceSchema(org, repo, version, resource.plural, resource.group, resource.version)
} else {
  definitions = getDefinitions(org, repo, version)
  schema = getResourceSchemaFromDefinitions(org, repo, version, resource.kind, resource.group)
}

const hasSchema = schema !== null

const prevVersion = (() => {
  const idx = ctrl.versions.indexOf(version)
  return ctrl.versions[idx + 1] ?? null
})()
const nextVersion = (() => {
  const idx = ctrl.versions.indexOf(version)
  return idx > 0 ? ctrl.versions[idx - 1] : null
})()

const resourceAssets = getResourceAssets(org, repo, version, resource.kind, resource.group, resource.version, resource.plural)
const meta = getControllerMeta(org, repo)
---

<Layout
  title={`${resource.kind} — ${org}/${repo} ${version}`}
  description={`Schema for ${resource.kind} (${resource.group}/${resource.version}) in ${org}/${repo} ${version}`}
  breadcrumbs={[
    { label: org, href: `${base}/` },
    { label: repo, href: `${base}/${org}/${repo}/` },
    { label: version, href: `${base}/${org}/${repo}/${version}/` },
    { label: resource.kind, href: `${base}/${org}/${repo}/${version}/${group}/${resource.kind}/` },
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Resource Header -->
    <div class="bg-white border border-zinc-200 rounded-xl p-6 mb-8 shadow-sm">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
        <div>
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
              resource.scope === 'Namespaced'
                ? 'bg-blue-100 text-blue-700'
                : 'bg-amber-100 text-amber-700'
            }`}>
              {resource.scope}
            </span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-violet-100 text-violet-700 font-mono">
              {version}
            </span>
            {resource.userManaged === false && (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-zinc-100 text-zinc-500 border border-zinc-200">
                system
              </span>
            )}
          </div>
          <h1 class="text-3xl font-bold text-zinc-900 font-mono mb-2">{resource.kind}</h1>
          <div class="flex flex-wrap gap-3 text-sm text-zinc-500">
            <span class="font-mono">
              {resource.group
                ? <><span class="text-zinc-400">group:</span> {resource.group}</>
                : <span class="text-zinc-400">core API</span>
              }
            </span>
            <span class="font-mono">
              <span class="text-zinc-400">version:</span> {resource.version}
            </span>
            <span class="font-mono">
              <span class="text-zinc-400">plural:</span> {resource.plural}
            </span>
          </div>
          {resource.shortNames && resource.shortNames.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              <span class="text-xs text-zinc-400">short names:</span>
              {resource.shortNames.map(sn => (
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono bg-zinc-100 text-zinc-600 border border-zinc-200">
                  {sn}
                </span>
              ))}
            </div>
          )}
          {schema?.description && (
            <p class="mt-4 text-sm text-zinc-600 leading-relaxed max-w-2xl">
              {schema.description}
            </p>
          )}
        </div>
        <div class="flex gap-2">
          {prevVersion && (
            <a
              href={`${base}/${org}/${repo}/${prevVersion}/${group}/${resource.kind}/`}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs bg-zinc-100 text-zinc-600 hover:bg-zinc-200 rounded-lg transition-colors font-mono"
            >
              ← {prevVersion}
            </a>
          )}
          {nextVersion && (
            <a
              href={`${base}/${org}/${repo}/${nextVersion}/${group}/${resource.kind}/`}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs bg-zinc-100 text-zinc-600 hover:bg-zinc-200 rounded-lg transition-colors font-mono"
            >
              {nextVersion} →
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Files & Links -->
    {(resourceAssets.jsonSchemaSource || resourceAssets.jsonSchemaLive || resourceAssets.crdFile || meta?.repository) && (
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-zinc-800 mb-4">Files &amp; Links</h2>
        <div class="bg-white border border-zinc-200 rounded-xl shadow-sm divide-y divide-zinc-100">

          {/* GitHub tree link */}
          <a
            href={resourceAssets.githubTree}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
          >
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              <div>
                <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">Browse on GitHub</span>
                <span class="ml-2 text-xs text-zinc-400 font-mono">schemas/{org}/{repo}/{version}/</span>
              </div>
            </div>
            <svg class="w-3.5 h-3.5 text-zinc-300 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>

          {/* Controller GitHub repo */}
          {meta?.repository && (
            <a
              href={`${meta.repository}/tree/${version}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
                <div>
                  <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">Controller source</span>
                  <span class="ml-2 text-xs text-zinc-400 font-mono">{meta.repository.replace('https://github.com/', '')}@{version}</span>
                </div>
              </div>
              <svg class="w-3.5 h-3.5 text-zinc-300 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}

          {/* CRD YAML */}
          {resourceAssets.crdFile && (
            <a
              href={resourceAssets.crdFile}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <div>
                  <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">CRD definition</span>
                  <span class="ml-2 text-xs text-zinc-400 font-mono">crd/{resource.plural}.{resource.group}.yaml</span>
                </div>
              </div>
              <svg class="w-3.5 h-3.5 text-zinc-300 group-hover:text-violet-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}

          {/* JSON Schema source */}
          {resourceAssets.jsonSchemaSource && (
            <a
              href={resourceAssets.jsonSchemaSource}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                <div>
                  <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">JSON Schema</span>
                  <span class="ml-2 text-xs text-zinc-400 font-mono">json-schema/source/{resourceAssets.jsonSchemaFile}</span>
                </div>
              </div>
              <span class="text-xs text-zinc-400 bg-zinc-100 px-2 py-0.5 rounded font-mono">source</span>
            </a>
          )}

          {/* JSON Schema live */}
          {resourceAssets.jsonSchemaLive && (
            <a
              href={resourceAssets.jsonSchemaLive}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                <div>
                  <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">JSON Schema</span>
                  <span class="ml-2 text-xs text-zinc-400 font-mono">json-schema/live/{resourceAssets.jsonSchemaFile}</span>
                </div>
              </div>
              <span class="text-xs text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded font-mono">live</span>
            </a>
          )}

          {/* _definitions.json source */}
          {resourceAssets.definitionsSource && (
            <a
              href={resourceAssets.definitionsSource}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                <div>
                  <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">All definitions</span>
                  <span class="ml-2 text-xs text-zinc-400 font-mono">json-schema/source/_definitions.json</span>
                  {resourceAssets.definitionKey && (
                    <button
                      data-copy={resourceAssets.definitionKey}
                      title="Copy $ref name"
                      class="ml-2 text-xs font-mono text-violet-500 hover:text-violet-700 hover:bg-violet-50 px-1 py-0.5 rounded transition-colors cursor-copy"
                    >
                      #{resourceAssets.definitionKey}
                    </button>
                  )}
                </div>
              </div>
              <span class="text-xs text-zinc-400 bg-zinc-100 px-2 py-0.5 rounded font-mono">source</span>
            </a>
          )}

          {/* _definitions.json live */}
          {resourceAssets.definitionsLive && (
            <a
              href={resourceAssets.definitionsLive}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-between px-4 py-3 hover:bg-zinc-50 transition-colors group"
            >
              <div class="flex items-center gap-3">
                <svg class="w-4 h-4 text-zinc-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                <div>
                  <span class="text-sm font-medium text-zinc-700 group-hover:text-violet-700 transition-colors">All definitions</span>
                  <span class="ml-2 text-xs text-zinc-400 font-mono">json-schema/live/_definitions.json</span>
                  {resourceAssets.definitionKey && (
                    <button
                      data-copy={resourceAssets.definitionKey}
                      title="Copy $ref name"
                      class="ml-2 text-xs font-mono text-violet-500 hover:text-violet-700 hover:bg-violet-50 px-1 py-0.5 rounded transition-colors cursor-copy"
                    >
                      #{resourceAssets.definitionKey}
                    </button>
                  )}
                </div>
              </div>
              <span class="text-xs text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded font-mono">live</span>
            </a>
          )}

        </div>
      </div>
    )}

    <!-- Schema Tree or Message -->
    {!hasSchema ? (
      <div class="bg-white border border-zinc-200 rounded-xl p-12 text-center shadow-sm">
        <div class="w-16 h-16 rounded-2xl bg-zinc-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-zinc-700 mb-2">Schema available via OpenAPI</h2>
        <p class="text-zinc-400 text-sm max-w-md mx-auto">
          This resource is a Kubernetes built-in type. Its schema is part of the
          core Kubernetes OpenAPI specification.
        </p>
        <a
          href={`https://kubernetes.io/docs/reference/kubernetes-api/`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 mt-4 px-4 py-2 text-sm bg-violet-600 text-white rounded-lg hover:bg-violet-700 transition-colors"
        >
          View Kubernetes API Reference
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    ) : (
      <div class="bg-white border border-zinc-200 rounded-xl shadow-sm overflow-hidden">
        <div class="bg-zinc-50 border-b border-zinc-200 px-6 py-4 flex items-center justify-between">
          <h2 class="text-base font-semibold text-zinc-700">Schema</h2>
          <div class="flex items-center gap-3 text-xs text-zinc-400">
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full bg-violet-400 inline-block"></span>
              required
            </span>
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full bg-zinc-300 inline-block"></span>
              optional
            </span>
          </div>
        </div>
        <div class="p-4">
          <PropertyTree schema={schema} definitions={definitions} client:load />
        </div>
      </div>
    )}

    {changeHistory.length > 0 && (
      <div class="mt-8">
        <ChangeHistory history={changeHistory} label={label} client:load />
      </div>
    )}
  </div>
</Layout>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('[data-copy]') as HTMLElement | null
    if (!btn) return
    e.stopPropagation()
    e.preventDefault()
    const text = btn.dataset.copy!
    navigator.clipboard.writeText(text).then(() => {
      const orig = btn.textContent!
      btn.textContent = 'Copied!'
      setTimeout(() => { btn.textContent = orig }, 1200)
    })
  })
</script>
