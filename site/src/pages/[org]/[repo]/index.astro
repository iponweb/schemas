---
import Layout from '../../../layouts/Layout.astro'
import ControllerIcon from '../../../components/ControllerIcon.astro'
import { getAllControllers, getResources, getVersionDiff } from '../../../lib/data'
import type { GetStaticPaths } from 'astro'

export const getStaticPaths: GetStaticPaths = async () => {
  const controllers = getAllControllers()
  return controllers.map(ctrl => ({
    params: { org: ctrl.org, repo: ctrl.repo },
    props: { ctrl },
  }))
}

const { ctrl } = Astro.props
const { org, repo } = Astro.params
const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const latestVersion = ctrl.versions[0]
const latestResources = latestVersion ? getResources(org, repo, latestVersion) : []

// Compute diff summaries for each version
const versionInfos = ctrl.versions.map((version, i) => {
  const resources = getResources(org, repo, version)
  const prevVersion = ctrl.versions[i + 1]
  let diff = null
  if (prevVersion) {
    try {
      diff = getVersionDiff(org, repo, version, prevVersion)
    } catch {
      // skip
    }
  }
  return { version, resources, diff }
})
---

<Layout
  title={`${org}/${repo}`}
  description={`Schema documentation for ${org}/${repo}`}
  breadcrumbs={[
    { label: org, href: `${base}/` },
    { label: repo, href: `${base}/${org}/${repo}/` },
  ]}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Controller Header -->
    <div class="bg-white border border-zinc-200 rounded-xl p-6 mb-8 shadow-sm">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div class="flex items-center gap-4">
          <ControllerIcon org={org} repo={repo} size="lg" />
          <div>
            <div class="text-sm text-zinc-400 mb-1">{org}/</div>
            <h1 class="text-3xl font-bold text-zinc-900">{repo}</h1>
          </div>
        </div>
        <div class="flex flex-wrap gap-3">
          <div class="bg-zinc-50 border border-zinc-200 rounded-lg px-4 py-3 text-center">
            <div class="text-2xl font-bold text-violet-600">{ctrl.versions.length}</div>
            <div class="text-xs text-zinc-500 mt-0.5">versions</div>
          </div>
          <div class="bg-zinc-50 border border-zinc-200 rounded-lg px-4 py-3 text-center">
            <div class="text-2xl font-bold text-zinc-800">{latestResources.length}</div>
            <div class="text-xs text-zinc-500 mt-0.5">resources</div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Version Timeline -->
      <div class="lg:col-span-1">
        <h2 class="text-lg font-semibold text-zinc-800 mb-4">Versions</h2>
        <div class="space-y-2">
          {versionInfos.map(({ version, resources, diff }, i) => (
            <a
              href={`${base}/${org}/${repo}/${version}/`}
              class="group block bg-white border border-zinc-200 rounded-xl p-4 shadow-sm hover:shadow-md hover:border-violet-200 transition-all duration-200"
            >
              <div class="flex items-center justify-between mb-2">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold ${
                  i === 0
                    ? 'bg-violet-100 text-violet-700'
                    : 'bg-zinc-100 text-zinc-600'
                }`}>
                  {version}
                </span>
                {i === 0 && (
                  <span class="text-xs text-violet-500 font-medium">latest</span>
                )}
              </div>
              <div class="text-sm text-zinc-500 mb-2">
                {resources.length} resources
              </div>
              {diff && (diff.added.length > 0 || diff.removed.length > 0 || diff.changed.length > 0) ? (
                <div class="flex flex-wrap gap-2 text-xs">
                  {diff.added.length > 0 && (
                    <span class="inline-flex items-center gap-1 text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded">
                      +{diff.added.length} added
                    </span>
                  )}
                  {diff.removed.length > 0 && (
                    <span class="inline-flex items-center gap-1 text-rose-600 bg-rose-50 px-2 py-0.5 rounded">
                      -{diff.removed.length} removed
                    </span>
                  )}
                  {diff.changed.length > 0 && (
                    <span class="inline-flex items-center gap-1 text-amber-600 bg-amber-50 px-2 py-0.5 rounded">
                      ~{diff.changed.length} changed
                    </span>
                  )}
                </div>
              ) : diff ? (
                <span class="text-xs text-zinc-400">No changes</span>
              ) : null}
            </a>
          ))}
        </div>
      </div>

      <!-- Latest Version Resources -->
      <div class="lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-semibold text-zinc-800">
            Resources
            {latestVersion && (
              <span class="text-sm font-normal text-zinc-400 ml-2">({latestVersion})</span>
            )}
          </h2>
          {latestVersion && (
            <a
              href={`${base}/${org}/${repo}/${latestVersion}/`}
              class="text-sm text-violet-600 hover:text-violet-800 font-medium transition-colors"
            >
              View full version →
            </a>
          )}
        </div>

        {latestResources.length > 0 ? (
          <div class="bg-white border border-zinc-200 rounded-xl shadow-sm overflow-hidden">
            <table class="w-full text-sm">
              <thead class="bg-zinc-50 border-b border-zinc-200">
                <tr>
                  <th class="text-left px-4 py-3 font-semibold text-zinc-600">Kind</th>
                  <th class="text-left px-4 py-3 font-semibold text-zinc-600">Group</th>
                  <th class="text-left px-4 py-3 font-semibold text-zinc-600">Version</th>
                  <th class="text-left px-4 py-3 font-semibold text-zinc-600">Scope</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-100">
                {latestResources.map(resource => (
                  <tr class={`hover:bg-zinc-50 transition-colors group ${resource.userManaged === false ? 'opacity-60' : ''}`}>
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-2">
                        <a
                          href={`${base}/${org}/${repo}/${latestVersion}/${resource.group || 'core'}/${resource.kind}/`}
                          class="font-mono font-medium text-violet-700 hover:text-violet-900 transition-colors"
                        >
                          {resource.kind}
                        </a>
                        {resource.userManaged === false && (
                          <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-zinc-100 text-zinc-500 border border-zinc-200">
                            system
                          </span>
                        )}
                      </div>
                    </td>
                    <td class="px-4 py-3 font-mono text-xs text-zinc-500">
                      {resource.group || <span class="text-zinc-300 italic">core</span>}
                    </td>
                    <td class="px-4 py-3 font-mono text-xs text-zinc-500">
                      {resource.version}
                    </td>
                    <td class="px-4 py-3">
                      <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${
                        resource.scope === 'Namespaced'
                          ? 'bg-blue-100 text-blue-700'
                          : 'bg-amber-100 text-amber-700'
                      }`}>
                        {resource.scope}
                      </span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ) : (
          <div class="bg-zinc-50 border border-zinc-200 rounded-xl p-8 text-center text-zinc-400">
            No resources found
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>
