---
import Layout from '../layouts/Layout.astro'
import ControllerIcon from '../components/ControllerIcon.astro'
import { getAllControllers, getResources } from '../lib/data'

const controllers = getAllControllers()

// Group by org
const byOrg = new Map<string, typeof controllers>()
for (const ctrl of controllers) {
  if (!byOrg.has(ctrl.org)) byOrg.set(ctrl.org, [])
  byOrg.get(ctrl.org)!.push(ctrl)
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// Pre-fetch resource counts for latest version
const controllerData = controllers.map(ctrl => {
  const latestVersion = ctrl.versions[0]
  const resources = latestVersion ? getResources(ctrl.org, ctrl.repo, latestVersion) : []
  return { ...ctrl, latestVersion, resourceCount: resources.length }
})

const byOrgData = new Map<string, typeof controllerData>()
for (const ctrl of controllerData) {
  if (!byOrgData.has(ctrl.org)) byOrgData.set(ctrl.org, [])
  byOrgData.get(ctrl.org)!.push(ctrl)
}

const totalResources = controllerData.reduce((sum, c) => sum + c.resourceCount, 0)
---

<Layout title="Home" description="Kubernetes CRD Schema Explorer — browse schemas for all your controllers">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-violet-600 via-violet-700 to-violet-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-4">
          Kubernetes CRD<br />
          <span class="text-violet-200">Schema Explorer</span>
        </h1>
        <p class="text-lg text-violet-100 mb-8 leading-relaxed">
          Browse and explore JSON Schemas for Kubernetes built-in APIs and
          third-party controllers. Interactive field trees, version diffs, and
          full type documentation.
        </p>
        <div class="flex flex-wrap gap-6 text-sm text-violet-200">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <strong class="text-white">{controllers.length}</strong> controllers
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <strong class="text-white">{totalResources}</strong> resource types
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
            <strong class="text-white">{[...new Set(controllers.flatMap(c => c.versions))].length}</strong> versions tracked
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={`${base}/about/`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/10 hover:bg-white/20 text-violet-100 hover:text-white text-sm transition-colors border border-white/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            How it's built
          </a>
          <a
            href={`${base}/api/v1/index.json`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/10 hover:bg-white/20 text-violet-100 hover:text-white text-sm font-mono transition-colors border border-white/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            /api/v1/index.json
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Controllers grid: orgs in columns, controllers stacked inside -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {[...byOrgData.entries()].sort(([a], [b]) => a.localeCompare(b, undefined, { sensitivity: 'base' })).map(([org, ctrls]) => (
        <div class="bg-white border border-zinc-200 rounded-xl shadow-sm overflow-hidden">
          <!-- Org header -->
          <div class="px-4 py-3 bg-zinc-50 border-b border-zinc-200 flex items-center gap-2">
            <svg class="w-3.5 h-3.5 text-zinc-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm font-semibold text-zinc-700">{org}</span>
          </div>
          <!-- Controllers in this org -->
          <div class="divide-y divide-zinc-100">
            {ctrls.map(ctrl => (
              <a
                href={`${base}/${ctrl.org}/${ctrl.repo}/`}
                class="group flex items-center gap-3 px-4 py-3.5 hover:bg-zinc-50 transition-colors"
              >
                <ControllerIcon org={ctrl.org} repo={ctrl.repo} size="sm" />
                <div class="min-w-0 flex-1">
                  <div class="font-medium text-zinc-900 group-hover:text-violet-700 transition-colors truncate">
                    {ctrl.repo}
                  </div>
                  <div class="text-xs text-zinc-400 mt-0.5 flex items-center gap-2">
                    <span>{ctrl.versions.length} {ctrl.versions.length === 1 ? 'version' : 'versions'}</span>
                    <span class="text-zinc-200">·</span>
                    <span>{ctrl.resourceCount} resources</span>
                  </div>
                </div>
                <span class="flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-violet-100 text-violet-700 font-mono">
                  {ctrl.latestVersion}
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
